{
  "uid": "synapse-system-overview",
  "title": "SynapseOMS — System Overview",
  "tags": ["synapse"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Order Submission Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(gateway_orders_submitted_total[1m]))",
          "legendFormat": "orders/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 2,
      "title": "Order Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(gateway_order_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(gateway_order_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(gateway_order_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 5 }
        }
      }
    },
    {
      "id": 3,
      "title": "Fill Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(gateway_fills_received_total[1m]))",
          "legendFormat": "fills/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 4,
      "title": "Active WebSocket Connections",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "gateway_active_websocket_connections",
          "legendFormat": "connections"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "VaR Computation Time (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(risk_var_computation_seconds_bucket[5m])) by (le, method))",
          "legendFormat": "p50 {{method}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(risk_var_computation_seconds_bucket[5m])) by (le, method))",
          "legendFormat": "p99 {{method}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 5 }
        }
      }
    },
    {
      "id": 6,
      "title": "Pre-Trade Check Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(risk_pretrade_check_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(risk_pretrade_check_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 5 }
        }
      }
    },
    {
      "id": 7,
      "title": "Pre-Trade Rejection Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(risk_pretrade_check_rejected_total[1m])",
          "legendFormat": "rejections/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        }
      }
    },
    {
      "id": 8,
      "title": "Portfolio VaR Ratio",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "risk_portfolio_var_ratio",
          "legendFormat": "VaR / NAV"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 0.2,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Anomalies Detected Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "datasource": { "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(risk_anomalies_detected_total[5m])",
          "legendFormat": "anomalies/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        }
      }
    }
  ]
}
