# SynapseOMS Environment Configuration
# Copy this file to .env and fill in the values.

# REQUIRED: Master passphrase for encrypting venue API credentials.
# Choose a strong passphrase — it protects all stored credentials.
SYNAPSE_MASTER_PASSPHRASE=change-me-to-a-strong-passphrase

# OPTIONAL: Anthropic API key for AI features (execution analysis, NL rebalancing).
# Without this, the system works normally but AI features are disabled.
# ANTHROPIC_API_KEY=sk-ant-...
